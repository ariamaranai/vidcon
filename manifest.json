{
  "manifest_version": 3,
  "name": "vidcon",
  "version": "0",
  "description": "Video controller",
  "icons": {
    "128": "off.png"
  },
  "permissions": [
    "scripting",
    "system.display",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "bg.js"
  },
  "action": {}
}